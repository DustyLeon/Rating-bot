# Copy this to .env for local dev (never commit .env to git)
# On Railway, set these in the Variables tab instead.

# Your bot's token from Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# The channel ID of #community-artist-choice-feed
# Right-click the channel → Copy Channel ID (requires Developer Mode to be on)
CHANNEL_ID=your_channel_id_here

# Injected automatically by Railway's PostgreSQL plugin — no action needed on Railway.
# For local dev, paste your connection string here.
DATABASE_URL=postgresql://user:password@host:5432/dbname
